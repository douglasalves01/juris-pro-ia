# Copie para .env.lexai e preencha as chaves reais.
# Docker Compose referencia este arquivo para o serviço lexai-api.

# Google Gemini (Vertex-style API key from AI Studio / Google Cloud)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Cohere (embed + rerank para RAG)
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-multilingual-v3.0
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# Secret JWT do projeto Supabase (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated

# Desenvolvimento local sem Supabase (não use em produção)
LEXAI_AUTH_DISABLED=false

DATABASE_URL=postgresql://lexai:lexai@localhost:5433/lexai
REDIS_URL=redis://localhost:6380/0

# Origens do frontend (outro repositório), separadas por vírgula. Inclua URL exata do app (protocolo + host + porta).
# Ex.: https://app.exemplo.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

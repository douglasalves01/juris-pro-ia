# =============================================================================
# JurisPro IA — microserviço de IA
# Copie para .env e preencha os valores antes de subir o projeto.
#
# Este serviço não tem auth. Recebe requisições do NestJS e devolve resultados.
# =============================================================================

# -----------------------------------------------------------------------------
# RabbitMQ (broker de mensagens entre NestJS e este microserviço)
# NestJS publica → worker consome e processa → worker publica resultado → NestJS consome
# No Docker Compose o host é "rabbitmq"; fora do Docker use localhost
# -----------------------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

# -----------------------------------------------------------------------------
# Qdrant (busca vetorial — casos similares, cache semântico, RAG privado)
# No Docker Compose o host é "qdrant"; fora do Docker use localhost
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Backend do cache semântico: "auto" (tenta Qdrant, cai em memória) | "memory"
JURISPRO_SEMANTIC_CACHE_BACKEND=auto

# Similaridade mínima para reutilizar resultado do cache semântico (0.0–1.0)
JURISPRO_SEMANTIC_CACHE_THRESHOLD=0.96

# Backend do RAG privado por escritório: "auto" (tenta Qdrant) | "memory"
JURISPRO_PRIVATE_RAG_BACKEND=auto

# -----------------------------------------------------------------------------
# Google Gemini (LLM externo)
# Opcional: sem essa chave o sistema funciona 100% com modelos locais.
# Quando configurado, enriquece pareceres de alto risco, resumos para clientes
# e geração de minutas.
# -----------------------------------------------------------------------------
JURISPRO_GEMINI_API_KEY=AIza...
JURISPRO_GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------------
# Armazenamento e modelos
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MODELS_DIR=/app/hf_models
MAX_UPLOAD_BYTES=52428800

# -----------------------------------------------------------------------------
# Personalização
# -----------------------------------------------------------------------------
# Nome exibido no PDF de resumo para cliente
JURISPRO_BRAND_NAME=JurisPro IA

# Webhook para receber obrigações/prazos extraídos (NestJS ou outro backend)
# Deixe vazio para desabilitar
JURISPRO_OBLIGATIONS_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# CORS
# Se o microserviço for interno (só acessado pelo NestJS na mesma rede Docker),
# pode restringir ou desabilitar CORS completamente.
# -----------------------------------------------------------------------------
CORS_ORIGINS=["*"]

# -----------------------------------------------------------------------------
# Opções de desenvolvimento / debug
# -----------------------------------------------------------------------------
# Pula o pré-carregamento dos modelos na inicialização (útil em dev/testes)
JURISPRO_SKIP_PRELOAD=false

# Expõe detalhes de exceção nas respostas de erro (NUNCA ative em produção)
JURISPRO_DEBUG_ERRORS=false

# Limite de metadados de jobs assíncronos mantidos em memória para polling local
JURISPRO_MAX_ASYNC_JOBS=500

# --- Obrigatório ---
# PostgreSQL (asyncpg) — use host "postgres" no Docker Compose
DATABASE_URL=postgresql+asyncpg://jurispro:jurispro@postgres:5432/jurispro
# Opcional: URL síncrona (psycopg2) para Alembic, seed e pgvector; se omitido, deriva de DATABASE_URL
# DATABASE_URL_SYNC=postgresql+psycopg2://jurispro:jurispro@postgres:5432/jurispro

JWT_SECRET=troque-por-uma-chave-longa-e-aleatoria-em-producao

# --- Redis / Celery (host "redis" no Docker Compose) ---
REDIS_URL=redis://redis:6379/0

# --- API ---
# Pesos HuggingFace / joblibs por tarefa (volume Docker: ./hf_models -> /app/hf_models)
UPLOAD_DIR=/app/uploads
MODELS_DIR=/app/hf_models
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
MAX_UPLOAD_BYTES=52428800
CORS_ORIGINS=["*"]

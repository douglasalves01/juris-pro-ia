# =============================================================================
# JurisPro IA — microserviço de IA
#
# Este serviço não tem auth, não tem banco de dados, não gerencia usuários.
# Recebe requisições do backend NestJS (HTTP ou RabbitMQ) e devolve resultados.
# =============================================================================

# -----------------------------------------------------------------------------
# RabbitMQ (o backend sobe, a gente só se conecta)
# -----------------------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

# -----------------------------------------------------------------------------
# Qdrant (busca vetorial — sobe no docker-compose deste repo)
# -----------------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Cache semântico: "auto" tenta Qdrant, cai em memória se offline | "memory" força local
JURISPRO_SEMANTIC_CACHE_BACKEND=auto
JURISPRO_SEMANTIC_CACHE_THRESHOLD=0.96

# RAG privado por escritório: "auto" tenta Qdrant | "memory" força local
JURISPRO_PRIVATE_RAG_BACKEND=auto

# -----------------------------------------------------------------------------
# Google Gemini (opcional — sem isso tudo funciona com modelos locais)
# -----------------------------------------------------------------------------
JURISPRO_GEMINI_API_KEY=
JURISPRO_GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Armazenamento e modelos
# -----------------------------------------------------------------------------
MODELS_DIR=/app/hf_models
MAX_UPLOAD_BYTES=52428800

# -----------------------------------------------------------------------------
# CORS (em produção restringir para URL do backend)
# -----------------------------------------------------------------------------
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# Dev / debug
# -----------------------------------------------------------------------------
JURISPRO_SKIP_PRELOAD=false
JURISPRO_DEBUG_ERRORS=false
JURISPRO_MAX_ASYNC_JOBS=500

DATAJUD_API_KEY=cDZHYzlZa0JadVREZDJCendQbXY6SkJlTzNjLV9TRENyQk1RdnFKZGRQdw
